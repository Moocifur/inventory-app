<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
</head>
<body>
    <a href="/categories">← Back to Categories</a>
    <h1>Edit Product</h1>
    <form method="POST" action="/products/<%= product.id %>/edit">
        <div>
            <label for="item_no">Item No:</label>
            <input type="text" id="item_no" name="item_no" value="<%= product.item_no %>" required>
        </div>
        <div>
            <label for="alliant_part_no">Allaint Part No:</label>
            <input type="text" id="alliant_part_no" name="alliant_part_no" value="<%= product.alliant_part_no %>" required>
        </div>
        <div>
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" value="<%= product.name %>" required>
        </div>
        <div>
            <label for="product_group_id">Product Group ID:</label>
            <input type="number" id="product_group_id" name="product_group_id" value="<%= product.product_group_id %>" required>
        </div>
        <div>
            <label for="quantity">Quantity:</label>
            <input type="number" id="quantity" name="quantity" value="<%= product.quantity %>" required>
        </div>
        <div>
            <label for="weight">Weight:</label>
            <input type="number" id="weight" name="weight" value="<%= product.weight %>" required>
        </div>
        <div>
            <label for="upc">UPC:</label>
            <input type="text" id="upc" name="upc" value="<%= product.upc %>" required>
        </div>
        <div>
            <label for="country_of_origin">Country Of Origin:</label>
            <input type="text" id="country_of_origin" name="country_of_origin" value="<%= product.country_of_origin %>" required>
        </div>
        <button type="submit">Update Product</button>
    </form>
</body>
</html>